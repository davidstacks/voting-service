<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>

    <div class="page-header">
      <div>
        <h2><i class="fas fa-chart-line"></i> Admin Dashboard</h2>
        <p>System overview and election management</p>
      </div>
      <a href="/admin/elections/new" class="btn btn-primary"><i class="fas fa-plus"></i> New Election</a>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card blue">
        <div class="stat-icon">👥</div>
        <div class="stat-value"><%= stats.totalVoters %></div>
        <div class="stat-label">Registered Voters</div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon">✅</div>
        <div class="stat-value"><%= stats.verifiedVoters %></div>
        <div class="stat-label">Verified Voters</div>
      </div>
      <div class="stat-card purple">
        <div class="stat-icon">🗳️</div>
        <div class="stat-value"><%= stats.totalVotesCast %></div>
        <div class="stat-label">Total Votes Cast</div>
      </div>
      <div class="stat-card yellow">
        <div class="stat-icon">📊</div>
        <div class="stat-value"><%= stats.activeElections %></div>
        <div class="stat-label">Active Elections</div>
      </div>
      <div class="stat-card blue">
        <div class="stat-icon">📁</div>
        <div class="stat-value"><%= stats.totalElections %></div>
        <div class="stat-label">Total Elections</div>
      </div>
      <div class="stat-card red">
        <div class="stat-icon">🔒</div>
        <div class="stat-value"><%= stats.lockedAccounts %></div>
        <div class="stat-label">Locked Accounts</div>
      </div>
    </div>

    <!-- Elections -->
    <div class="card" style="margin-bottom: 2rem;">
      <div class="card-header">
        <h3><i class="fas fa-list"></i> Elections</h3>
        <a href="/admin/elections/new" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Create</a>
      </div>

      <% if (elections.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-inbox"></i>
          <h3>No Elections</h3>
          <p>Create your first election to get started.</p>
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Candidates</th>
                <th>Votes</th>
                <th>Turnout</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% elections.forEach(el => { %>
                <tr>
                  <td><strong><%= el.title %></strong></td>
                  <td>
                    <% if (el.status === 'active') { %>
                      <span class="badge badge-success">ACTIVE</span>
                    <% } else if (el.status === 'closed') { %>
                      <span class="badge badge-danger">CLOSED</span>
                    <% } else if (el.status === 'draft') { %>
                      <span class="badge badge-warning">DRAFT</span>
                    <% } else if (el.status === 'paused') { %>
                      <span class="badge badge-info">PAUSED</span>
                    <% } else { %>
                      <span class="badge badge-gray"><%= el.status.toUpperCase() %></span>
                    <% } %>
                  </td>
                  <td><%= el.candidateCount %></td>
                  <td><%= el.voteCount %></td>
                  <td><%= el.turnout %>%</td>
                  <td><%= new Date(el.start_date).toLocaleDateString() %></td>
                  <td><%= new Date(el.end_date).toLocaleDateString() %></td>
                  <td>
                    <a href="/admin/elections/<%= el.id %>" class="btn btn-outline btn-sm"><i class="fas fa-eye"></i></a>
                    <a href="/admin/elections/<%= el.id %>/edit" class="btn btn-outline btn-sm"><i class="fas fa-edit"></i></a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Recent Activity -->
    <div class="card">
      <div class="card-header">
        <h3><i class="fas fa-clock-rotate-left"></i> Recent Activity</h3>
        <a href="/admin/audit" class="btn btn-outline btn-sm">View All</a>
      </div>
      <% if (recentActivity.length === 0) { %>
        <p style="color: var(--text-muted); text-align: center; padding: 1rem;">No activity recorded yet.</p>
      <% } else { %>
        <% recentActivity.forEach(log => { %>
          <div class="activity-item">
            <div class="activity-dot <%= log.action.includes('LOGIN') ? 'login' : log.action.includes('VOTE') ? 'vote' : log.action.includes('ERROR') ? 'error' : 'admin' %>"></div>
            <div class="activity-text">
              <strong><%= log.username || 'System' %></strong> — <%= log.action %>
              <% if (log.details) { %><span style="color: var(--text-dim);"> — <%= log.details %></span><% } %>
            </div>
            <div class="activity-time"><%= new Date(log.created_at).toLocaleString() %></div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
