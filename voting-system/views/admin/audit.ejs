<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>

    <div class="page-header">
      <div>
        <h2><i class="fas fa-clipboard-list"></i> Audit Log</h2>
        <p>Complete security audit trail of all system actions</p>
      </div>
      <a href="/admin" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <div class="security-banner">
      <i class="fas fa-shield-halved"></i>
      <span>Immutable audit trail — All actions are permanently recorded with timestamps, IPs, and user agents</span>
    </div>

    <div class="card">
      <% if (logs.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-clipboard-list"></i>
          <h3>No Activity</h3>
          <p>No actions have been recorded yet.</p>
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Time</th>
                <th>User</th>
                <th>Action</th>
                <th>Details</th>
                <th>IP Address</th>
              </tr>
            </thead>
            <tbody>
              <% logs.forEach(log => { %>
                <tr>
                  <td style="white-space: nowrap;"><%= new Date(log.created_at).toLocaleString() %></td>
                  <td><strong><%= log.username || 'System' %></strong></td>
                  <td>
                    <% if (log.action.includes('LOGIN_SUCCESS')) { %>
                      <span class="badge badge-success">LOGIN</span>
                    <% } else if (log.action.includes('LOGIN_FAILED') || log.action.includes('LOGIN_BLOCKED')) { %>
                      <span class="badge badge-danger"><%= log.action %></span>
                    <% } else if (log.action.includes('VOTE')) { %>
                      <span class="badge badge-info">VOTE</span>
                    <% } else if (log.action.includes('REGISTER')) { %>
                      <span class="badge badge-purple">REGISTER</span>
                    <% } else { %>
                      <span class="badge badge-gray"><%= log.action %></span>
                    <% } %>
                  </td>
                  <td style="color: var(--text-muted); max-width: 250px; overflow: hidden; text-overflow: ellipsis;"><%= log.details || '—' %></td>
                  <td><code style="font-size: 0.75rem;"><%= log.ip_address || '—' %></code></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
