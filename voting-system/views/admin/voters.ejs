<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>

    <div class="page-header">
      <div>
        <h2><i class="fas fa-users"></i> Manage Voters</h2>
        <p>View, verify, and manage registered voter accounts</p>
      </div>
    </div>

    <div class="card">
      <% if (voters.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-users"></i>
          <h3>No Voters Registered</h3>
          <p>No students have registered yet.</p>
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Username</th>
                <th>Student ID</th>
                <th>Email</th>
                <th>Status</th>
                <th>Verified</th>
                <th>Last Login</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% voters.forEach(v => { %>
                <tr>
                  <td><strong><%= v.full_name %></strong></td>
                  <td><%= v.username %></td>
                  <td><code><%= v.student_id %></code></td>
                  <td><%= v.email %></td>
                  <td>
                    <% if (v.is_locked) { %>
                      <span class="badge badge-danger"><i class="fas fa-lock"></i> LOCKED</span>
                    <% } else { %>
                      <span class="badge badge-success"><i class="fas fa-unlock"></i> ACTIVE</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (v.is_verified) { %>
                      <span class="badge badge-success"><i class="fas fa-check"></i> YES</span>
                    <% } else { %>
                      <span class="badge badge-warning"><i class="fas fa-clock"></i> PENDING</span>
                    <% } %>
                  </td>
                  <td><%= v.last_login_at ? new Date(v.last_login_at).toLocaleString() : 'Never' %></td>
                  <td>
                    <div class="btn-group">
                      <form method="POST" action="/admin/voters/<%= v.id %>/toggle-verify" style="display:inline;">
                        <button type="submit" class="btn btn-sm <%= v.is_verified ? 'btn-warning' : 'btn-success' %>" title="<%= v.is_verified ? 'Revoke verification' : 'Verify voter' %>">
                          <i class="fas fa-<%= v.is_verified ? 'times' : 'check' %>"></i>
                        </button>
                      </form>
                      <form method="POST" action="/admin/voters/<%= v.id %>/toggle-lock" style="display:inline;">
                        <button type="submit" class="btn btn-sm <%= v.is_locked ? 'btn-success' : 'btn-danger' %>" title="<%= v.is_locked ? 'Unlock account' : 'Lock account' %>">
                          <i class="fas fa-<%= v.is_locked ? 'unlock' : 'lock' %>"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
