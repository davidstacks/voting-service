<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>

    <div class="page-header">
      <div>
        <h2><i class="fas fa-shield-halved"></i> Spam & Abuse Report</h2>
        <p>Blocked vote attempts, duplicate votes, and suspicious activity</p>
      </div>
      <a href="/admin" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <div class="security-banner">
      <i class="fas fa-lock"></i>
      <span>All blocked attempts are logged with device fingerprint, timestamp, and reason — tamper-proof audit trail</span>
    </div>

    <div class="card">
      <div class="card-header">
        <h3><i class="fas fa-ban"></i> Blocked Vote Attempts by User / Device</h3>
      </div>
      <% if (spamReport.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-check-circle" style="color: var(--accent);"></i>
          <h3>No Spam Detected</h3>
          <p>No blocked vote attempts have been recorded. The system is clean!</p>
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Full Name</th>
                <th>Device</th>
                <th>Reason</th>
                <th>Total Attempts</th>
                <th>Blocked</th>
                <th>Threat Level</th>
              </tr>
            </thead>
            <tbody>
              <% spamReport.forEach(row => { %>
                <tr>
                  <td><strong><%= row.username %></strong></td>
                  <td><%= row.full_name %></td>
                  <td><code title="<%= row.device_fingerprint || '' %>"><%= row.device_fingerprint ? row.device_fingerprint.substring(0, 12) + '...' : 'N/A' %></code></td>
                  <td><%= row.block_reason || 'N/A' %></td>
                  <td><%= row.attempts %></td>
                  <td><span class="badge badge-danger"><%= row.blocked_count %> BLOCKED</span></td>
                  <td>
                    <% if (row.blocked_count >= 10) { %>
                      <span class="badge badge-danger"><i class="fas fa-exclamation-triangle"></i> HIGH</span>
                    <% } else if (row.blocked_count >= 5) { %>
                      <span class="badge badge-warning"><i class="fas fa-exclamation"></i> MEDIUM</span>
                    <% } else { %>
                      <span class="badge badge-info">LOW</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Shared Device Report -->
    <div class="card" style="margin-top: 2rem;">
      <div class="card-header">
        <h3><i class="fas fa-desktop"></i> Shared Device Detection</h3>
      </div>
      <% if (sharedDevices.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-check-circle" style="color: var(--accent);"></i>
          <h3>No Shared Devices</h3>
          <p>No devices have been used by multiple accounts.</p>
        </div>
      <% } else { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Device Fingerprint</th>
                <th>Users Sharing Device</th>
                <th>Usernames</th>
                <th>Risk</th>
              </tr>
            </thead>
            <tbody>
              <% sharedDevices.forEach(row => { %>
                <tr>
                  <td><code title="<%= row.fingerprint %>"><%= row.fingerprint.substring(0, 16) %>...</code></td>
                  <td><strong><%= row.user_count %></strong></td>
                  <td><%= row.usernames %></td>
                  <td>
                    <% if (row.user_count >= 5) { %>
                      <span class="badge badge-danger"><i class="fas fa-exclamation-triangle"></i> CRITICAL</span>
                    <% } else if (row.user_count >= 3) { %>
                      <span class="badge badge-warning"><i class="fas fa-exclamation"></i> SUSPICIOUS</span>
                    <% } else { %>
                      <span class="badge badge-info">MONITOR</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
