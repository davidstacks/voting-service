<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>

    <div class="page-header">
      <div>
        <h2><i class="fas fa-<%= election ? 'edit' : 'plus-circle' %>"></i> <%= election ? 'Edit Election' : 'Create New Election' %></h2>
        <p><%= election ? 'Modify election settings' : 'Set up a new election for voters' %></p>
      </div>
      <a href="/admin" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <div class="card" style="max-width: 700px;">
      <form method="POST" action="<%= election ? `/admin/elections/${election.id}/edit` : '/admin/elections' %>">
        <div class="form-group">
          <label for="title">Election Title</label>
          <input type="text" id="title" name="title" class="form-control" placeholder="e.g., Student Council President 2026" required value="<%= election ? election.title : '' %>">
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" class="form-control" placeholder="Describe what this election is for..." required><%= election ? election.description : '' %></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="startDate">Start Date & Time</label>
            <input type="datetime-local" id="startDate" name="startDate" class="form-control" required value="<%= election ? election.start_date.replace(' ', 'T').slice(0, 16) : '' %>">
          </div>
          <div class="form-group">
            <label for="endDate">End Date & Time</label>
            <input type="datetime-local" id="endDate" name="endDate" class="form-control" required value="<%= election ? election.end_date.replace(' ', 'T').slice(0, 16) : '' %>">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="maxVotes">Max Votes Per User</label>
            <input type="number" id="maxVotes" name="maxVotes" class="form-control" min="1" max="10" value="<%= election ? election.max_votes_per_user : 1 %>">
          </div>
          <div class="form-group" style="display: flex; align-items: end;">
            <div class="form-check">
              <input type="checkbox" id="isAnonymous" name="isAnonymous" <%= (!election || election.is_anonymous) ? 'checked' : '' %>>
              <label for="isAnonymous">Anonymous Voting</label>
            </div>
          </div>
        </div>

        <div class="btn-group" style="margin-top: 1rem;">
          <button type="submit" class="btn btn-success btn-lg">
            <i class="fas fa-save"></i> <%= election ? 'Save Changes' : 'Create Election' %>
          </button>
          <a href="/admin" class="btn btn-outline btn-lg">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
