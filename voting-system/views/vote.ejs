<%- include('partials/head') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/canvas-confetti/1.9.3/confetti.browser.min.js" defer></script>
<%- include('partials/nav') %>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
<% } %>

<div class="container" style="max-width: 720px; margin-top: 2rem;">

  <!-- Poll Header -->
  <div class="poll-header">
    <div class="poll-header-top">
      <span class="tag tag-category"><i class="fas <%= categoryObj.icon %>"></i> <%= categoryObj.label %></span>
      <% if (poll.poll_type && poll.poll_type !== 'choice') { %>
        <span class="tag tag-type"><%= poll.poll_type === 'yesno' ? 'Yes/No' : 'Rating' %></span>
      <% } %>
    </div>
    <h1 class="poll-title"><%= poll.title %></h1>
    <% if (poll.description) { %>
      <p class="poll-description"><%= poll.description %></p>
    <% } %>
    <div class="poll-meta">
      <span><i class="fas fa-users"></i> <%= totalVotes %> vote<%= totalVotes !== 1 ? 's' : '' %></span>
      <% if (poll.vote_cap) { %>
        <span><i class="fas fa-flag-checkered"></i> Goal: <%= poll.vote_cap %></span>
      <% } %>
      <% if (poll.is_closed) { %>
        <span class="badge badge-closed"><i class="fas fa-lock"></i> Closed</span>
      <% } else if (isExpired) { %>
        <span class="badge badge-closed"><i class="fas fa-clock"></i> Ended</span>
      <% } else if (isScheduled) { %>
        <span class="badge badge-scheduled"><i class="fas fa-calendar-clock"></i> Scheduled</span>
      <% } else { %>
        <span class="badge badge-open"><i class="fas fa-circle"></i> Active</span>
      <% } %>
      <% if (poll.end_date && !poll.is_closed && !isExpired) { %>
        <span class="poll-timer" data-end="<%= poll.end_date %>"><i class="fas fa-clock"></i> Ends: <%= new Date(poll.end_date).toLocaleString() %></span>
      <% } %>
    </div>
  </div>

  <!-- Scheduled Notice -->
  <% if (isScheduled && poll.start_date) { %>
    <div class="schedule-notice">
      <i class="fas fa-calendar-clock"></i>
      <div>
        <strong>This poll hasn't started yet</strong>
        <span>Voting opens on <strong><%= new Date(poll.start_date).toLocaleString() %></strong></span>
      </div>
      <span class="schedule-countdown" data-start="<%= poll.start_date %>"></span>
    </div>
  <% } %>

  <!-- Vote Cap Progress Bar -->
  <% if (poll.vote_cap && poll.vote_cap > 0) { %>
    <% const capPct = Math.min(100, (totalVotes / poll.vote_cap) * 100).toFixed(1); %>
    <div class="vote-goal-wrap">
      <div class="vote-goal-label">
        <span><i class="fas fa-bullseye"></i> Vote Goal Progress</span>
        <span><strong><%= totalVotes %></strong> / <%= poll.vote_cap %> (<%= capPct %>%)</span>
      </div>
      <div class="vote-goal-bar-bg">
        <div class="vote-goal-bar" style="width: <%= capPct %>%"></div>
      </div>
    </div>
  <% } %>

  <!-- Share & Embed Tabs -->
  <div class="share-card card">
    <div class="share-tabs">
      <button class="share-tab active" data-tab="link"><i class="fas fa-link"></i> Link</button>
      <button class="share-tab" data-tab="embed"><i class="fas fa-code"></i> Embed</button>
      <button class="share-tab" data-tab="qr"><i class="fas fa-qrcode"></i> QR Code</button>
    </div>
    <div class="share-content" id="share-link">
      <div class="share-bar">
        <input type="text" id="share-url" readonly onclick="this.select()">
        <button type="button" class="btn btn-primary btn-sm" id="copy-link"><i class="fas fa-copy"></i> Copy</button>
      </div>
    </div>
    <div class="share-content" id="share-embed" style="display: none;">
      <div class="share-bar">
        <input type="text" id="embed-code" readonly onclick="this.select()">
        <button type="button" class="btn btn-primary btn-sm" id="copy-embed"><i class="fas fa-copy"></i> Copy</button>
      </div>
      <p class="share-hint">Paste this HTML on any website to embed this poll.</p>
    </div>
    <div class="share-content" id="share-qr" style="display: none;">
      <div class="qr-container" id="qr-code"></div>
      <p class="share-hint">Scan with a phone camera to open this poll.</p>
    </div>
  </div>
  <script>
    document.getElementById('share-url').value = window.location.href;
    document.getElementById('embed-code').value = '<iframe src="' + window.location.href + '/embed" width="100%" height="500" frameborder="0"></iframe>';
  </script>

  <!-- Access Code Gate -->
  <% if (needsCode) { %>
    <div class="card">
      <h3 class="card-title"><i class="fas fa-lock"></i> Access Required</h3>
      <p class="card-subtitle">This vote requires an access code. Enter it below to participate.</p>
      <form method="POST" action="/v/<%= poll.slug %>/verify-access">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <div class="form-group">
          <label for="accessCode">Access Code <span class="required">*</span></label>
          <input type="text" id="accessCode" name="accessCode" placeholder="Enter the access code" required autocomplete="off" autofocus>
        </div>
        <button type="submit" class="btn btn-primary btn-full"><i class="fas fa-unlock"></i> Unlock Vote</button>
      </form>
    </div>
  <% } %>

  <!-- Voting Form -->
  <% if (canVote) { %>
    <div class="card voting-card">
      <h3><i class="fas fa-vote-yea"></i> Cast Your Vote</h3>
      <form id="vote-form" method="POST" action="/v/<%= poll.slug %>/vote">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <input type="hidden" name="deviceFingerprint" id="deviceFingerprint" value="">

        <% if (poll.require_name) { %>
          <div class="form-group">
            <label for="voterName">Your Name <span class="required">*</span></label>
            <input type="text" id="voterName" name="voterName" placeholder="Enter your name" required maxlength="100">
          </div>
        <% } %>

        <div class="options-list">
          <% if (poll.poll_type === 'rating') { %>
            <!-- Star Rating -->
            <div class="rating-stars">
              <% options.forEach((o, i) => { %>
                <label class="star-option" title="<%= o.label %>">
                  <input type="radio" name="optionId" value="<%= o.id %>" required>
                  <i class="fas fa-star"></i>
                </label>
              <% }); %>
            </div>
          <% } else { %>
            <% options.forEach(o => { %>
              <label class="option-card<%= poll.poll_type === 'yesno' ? ' yesno-card' : '' %>">
                <input type="<%= poll.allow_multiple ? 'checkbox' : 'radio' %>" name="optionId" value="<%= o.id %>" required>
                <span class="option-check"><i class="fas fa-check"></i></span>
                <span class="option-label">
                  <% if (poll.poll_type === 'yesno') { %>
                    <i class="fas fa-<%= o.label === 'Yes' ? 'thumbs-up' : 'thumbs-down' %>"></i>
                  <% } %>
                  <%= o.label %>
                </span>
              </label>
            <% }); %>
          <% } %>
        </div>

        <button type="submit" id="vote-submit" class="btn btn-primary btn-lg btn-full" disabled>
          <i class="fas fa-paper-plane"></i> Vote
        </button>
      </form>
    </div>
  <% } %>

  <% if (voted) { %>
    <div class="voted-banner">
      <i class="fas fa-check-circle"></i> You have voted! 🎉
    </div>
  <% } %>

  <!-- Results -->
  <% if (showResults && results) { %>
    <div class="card results-card" id="results-card" data-slug="<%= poll.slug %>">
      <div class="results-header">
        <h3><i class="fas fa-chart-bar"></i> Results</h3>
        <div class="results-actions">
          <button class="btn btn-outline btn-sm chart-toggle-btn" id="chart-toggle" type="button" title="Toggle chart type">
            <i class="fas fa-chart-pie"></i> Chart
          </button>
          <span class="live-indicator" id="live-dot"><i class="fas fa-circle"></i> Live</span>
          <a href="/v/<%= poll.slug %>/results" class="btn btn-outline btn-sm"><i class="fas fa-expand"></i> Full</a>
        </div>
      </div>
      <!-- Chart canvas (hidden by default, shown on toggle) -->
      <div class="chart-container" id="chart-container" style="display:none;">
        <canvas id="resultsChart" height="260"></canvas>
      </div>
      <div class="results-list" id="results-list">
        <% results.forEach(r => { %>
          <% const pct = totalVotes > 0 ? ((r.vote_count / totalVotes) * 100).toFixed(1) : 0; %>
          <div class="result-row">
            <div class="result-label">
              <span class="result-name"><%= r.label %></span>
              <span class="result-pct"><%= pct %>%</span>
            </div>
            <div class="result-bar-bg">
              <div class="result-bar" style="width: <%= pct %>%"></div>
            </div>
            <div class="result-votes"><%= r.vote_count %> vote<%= r.vote_count !== 1 ? 's' : '' %></div>
          </div>
        <% }); %>
      </div>
      <div class="total-votes-line"><i class="fas fa-users"></i> <span id="total-votes-num"><%= totalVotes %></span> total votes</div>
    </div>

    <!-- Social Share -->
    <div class="social-share-row">
      <span class="social-share-label"><i class="fas fa-share-nodes"></i> Share</span>
      <a class="social-btn social-btn-twitter" href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent('Vote: ' + poll.title) %>&url=<%= encodeURIComponent('https://' + (process.env.BASE_URL || 'localhost:3000') + '/v/' + poll.slug) %>" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-x-twitter"></i> X / Twitter
      </a>
      <a class="social-btn social-btn-whatsapp" href="https://wa.me/?text=<%= encodeURIComponent('Vote: ' + poll.title + ' — https://' + (process.env.BASE_URL || 'localhost:3000') + '/v/' + poll.slug) %>" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-whatsapp"></i> WhatsApp
      </a>
      <a class="social-btn social-btn-telegram" href="https://t.me/share/url?url=<%= encodeURIComponent('https://' + (process.env.BASE_URL || 'localhost:3000') + '/v/' + poll.slug) %>&text=<%= encodeURIComponent('Vote: ' + poll.title) %>" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-telegram"></i> Telegram
      </a>
      <button class="social-btn social-btn-copy" id="social-copy-btn" type="button">
        <i class="fas fa-link"></i> Copy Link
      </button>
    </div>

    <!-- Chart.js init data -->
    <script id="chart-data" type="application/json">
    {
      "labels": <%- JSON.stringify(results.map(r => r.label)) %>,
      "values": <%- JSON.stringify(results.map(r => r.vote_count)) %>
    }
    </script>
  <% } %>

  <!-- Comments Section -->
  <% if (!needsCode) { %>
    <div class="card comments-section" id="comments-section">
      <h3 class="comments-title"><i class="fas fa-comments"></i> Discussion <span class="comments-count" id="comments-count">(<%= comments.length %>)</span></h3>

      <!-- Comment Form -->
      <form class="comment-form" id="comment-form" data-slug="<%= poll.slug %>">
        <div class="comment-form-row">
          <input type="text" id="comment-author" placeholder="Your name (optional)" maxlength="100" class="comment-name-input">
          <span class="comment-divider"></span>
          <textarea id="comment-body" placeholder="Add a comment..." maxlength="1000" rows="2" required class="comment-textarea"></textarea>
        </div>
        <button type="submit" class="btn btn-outline btn-sm comment-submit-btn">
          <i class="fas fa-paper-plane"></i> Post Comment
        </button>
      </form>

      <!-- Comments List -->
      <div class="comments-list" id="comments-list">
        <% if (comments.length === 0) { %>
          <p class="comments-empty" id="comments-empty">No comments yet. Be the first!</p>
        <% } else { %>
          <% comments.forEach(c => { %>
            <div class="comment-item">
              <div class="comment-avatar"><i class="fas fa-user-circle"></i></div>
              <div class="comment-body-wrap">
                <div class="comment-meta">
                  <span class="comment-author"><%= c.author_name || 'Anonymous' %></span>
                  <span class="comment-time"><%= new Date(c.created_at).toLocaleString() %></span>
                </div>
                <div class="comment-text"><%= c.body %></div>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- Admin Controls -->
  <% if (isOwner || poll.admin_password_hash) { %>
    <div class="card admin-card">
      <h3><i class="fas fa-gear"></i> Manage Vote</h3>
      <% if (!isOwner) { %>
        <p class="card-subtitle">Enter the admin password to manage this vote.</p>
      <% } %>
      <form method="POST" action="/v/<%= poll.slug %>/admin" class="admin-form">
        <input type="hidden" name="_csrf" value="<%= csrf %>">
        <% if (!isOwner) { %>
          <div class="form-group">
            <input type="password" name="adminPassword" placeholder="Admin password" required>
          </div>
        <% } %>
        <div class="admin-buttons">
          <% if (poll.is_closed) { %>
            <button type="submit" name="action" value="reopen" class="btn btn-outline btn-sm"><i class="fas fa-unlock"></i> Reopen</button>
          <% } else { %>
            <button type="submit" name="action" value="close" class="btn btn-outline btn-sm"><i class="fas fa-lock"></i> Close Vote</button>
          <% } %>
          <button type="submit" name="action" value="duplicate" class="btn btn-outline btn-sm"><i class="fas fa-clone"></i> Duplicate</button>
          <button type="submit" name="action" value="delete" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this vote? This cannot be undone.')"><i class="fas fa-trash"></i> Delete</button>
        </div>
      </form>
    </div>
  <% } %>

</div>

<%- include('partials/site-footer') %>
<%- include('partials/footer') %>
