<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container">
  <div class="page-header">
    <div>
      <h1 class="page-title"><i class="fas fa-compass"></i> Explore Votes</h1>
      <p class="page-subtitle">Discover and participate in public polls</p>
    </div>
  </div>

  <!-- Search & Filters -->
  <form class="explore-filters" method="GET" action="/explore">
    <div class="search-bar">
      <i class="fas fa-search"></i>
      <input type="text" name="q" placeholder="Search polls..." value="<%= query %>" autocomplete="off">
      <button type="submit" class="btn btn-primary btn-sm">Search</button>
    </div>

    <div class="filter-row">
      <div class="filter-group">
        <label>Category</label>
        <select name="category" onchange="this.form.submit()">
          <option value="all" <%= category === 'all' ? 'selected' : '' %>>All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>" <%= category === cat.id ? 'selected' : '' %>>
              <%= cat.label %>
            </option>
          <% }); %>
        </select>
      </div>
      <div class="filter-group">
        <label>Sort by</label>
        <select name="sort" onchange="this.form.submit()">
          <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest</option>
          <option value="popular" <%= sort === 'popular' ? 'selected' : '' %>>Most Popular</option>
          <option value="active" <%= sort === 'active' ? 'selected' : '' %>>Recently Active</option>
        </select>
      </div>
    </div>
  </form>

  <!-- Results -->
  <% if (polls.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon"><i class="fas fa-search"></i></div>
      <h3>No polls found</h3>
      <p>Try a different search or browse all categories.</p>
      <a href="/explore" class="btn btn-outline">Clear Filters</a>
    </div>
  <% } else { %>
    <div class="explore-meta">
      <span><%= total %> poll<%= total !== 1 ? 's' : '' %> found</span>
    </div>

    <div class="poll-grid">
      <% polls.forEach(p => { %>
        <% const cat = categories.find(c => c.id === p.category) || categories[0]; %>
        <a href="/v/<%= p.slug %>" class="poll-card">
          <div class="poll-card-top">
            <span class="tag tag-category"><i class="fas <%= cat.icon %>"></i> <%= cat.label %></span>
            <% if (p.is_closed) { %>
              <span class="badge badge-closed">Closed</span>
            <% } else if (p.end_date && new Date(p.end_date) < new Date()) { %>
              <span class="badge badge-closed">Ended</span>
            <% } else { %>
              <span class="badge badge-open">Active</span>
            <% } %>
          </div>
          <div class="poll-card-title"><%= p.title %></div>
          <% if (p.description) { %>
            <div class="poll-card-desc"><%= p.description.substring(0, 80) %><%= p.description.length > 80 ? '...' : '' %></div>
          <% } %>
          <div class="poll-card-meta">
            <span><i class="fas fa-users"></i> <%= p.total_votes %> vote<%= p.total_votes !== 1 ? 's' : '' %></span>
            <span><i class="fas fa-clock"></i> <%= new Date(p.created_at).toLocaleDateString() %></span>
          </div>
        </a>
      <% }); %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="/explore?q=<%= query %>&category=<%= category %>&sort=<%= sort %>&page=<%= page - 1 %>" class="btn btn-outline btn-sm">
            <i class="fas fa-chevron-left"></i> Prev
          </a>
        <% } %>
        <span class="pagination-info">Page <%= page %> of <%= totalPages %></span>
        <% if (page < totalPages) { %>
          <a href="/explore?q=<%= query %>&category=<%= category %>&sort=<%= sort %>&page=<%= page + 1 %>" class="btn btn-outline btn-sm">
            Next <i class="fas fa-chevron-right"></i>
          </a>
        <% } %>
      </div>
    <% } %>
  <% } %>
</div>

<%- include('partials/site-footer') %>
<%- include('partials/footer') %>
