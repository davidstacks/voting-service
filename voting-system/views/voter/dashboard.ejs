<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>

    <div class="page-header">
      <div>
        <h2><i class="fas fa-home"></i> Voter Dashboard</h2>
        <p>Welcome back, <strong><%= user.full_name %></strong>! View and participate in active elections.</p>
      </div>
    </div>

    <div class="security-banner">
      <i class="fas fa-shield-halved"></i>
      <span>All votes are SHA-256 encrypted • One vote per election • Tamper-proof audit trail</span>
    </div>

    <div class="stats-grid">
      <div class="stat-card blue">
        <div class="stat-icon">🗳️</div>
        <div class="stat-value"><%= activeCount %></div>
        <div class="stat-label">Active Elections</div>
      </div>
      <div class="stat-card green">
        <div class="stat-icon">✅</div>
        <div class="stat-value"><%= elections.filter(e => e.hasVoted).length %></div>
        <div class="stat-label">Votes Cast</div>
      </div>
      <div class="stat-card purple">
        <div class="stat-icon">📋</div>
        <div class="stat-value"><%= elections.length %></div>
        <div class="stat-label">Total Elections</div>
      </div>
    </div>

    <% if (elections.filter(e => e.isActive && !e.hasVoted).length > 0) { %>
      <div class="card" style="margin-bottom: 2rem;">
        <div class="card-header">
          <h3><i class="fas fa-bolt" style="color: #fbbf24;"></i> Elections Awaiting Your Vote</h3>
        </div>
        <div class="election-grid">
          <% elections.filter(e => e.isActive && !e.hasVoted).forEach(el => { %>
            <div class="election-card">
              <span class="election-status"><span class="badge badge-success">ACTIVE</span></span>
              <h3><%= el.title %></h3>
              <p class="election-desc"><%= el.description %></p>
              <div class="election-meta">
                <span><i class="fas fa-users"></i> <%= el.candidateCount %> candidates</span>
                <span><i class="fas fa-clock"></i> Ends: <%= new Date(el.end_date).toLocaleDateString() %></span>
              </div>
              <a href="/dashboard/election/<%= el.id %>" class="btn btn-primary"><i class="fas fa-vote-yea"></i> Vote Now</a>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <div class="card">
      <div class="card-header">
        <h3><i class="fas fa-list"></i> All Elections</h3>
      </div>
      <% if (elections.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-inbox"></i>
          <h3>No Elections Yet</h3>
          <p>There are no elections available at this time. Check back later!</p>
        </div>
      <% } else { %>
        <div class="election-grid">
          <% elections.forEach(el => { %>
            <div class="election-card">
              <span class="election-status">
                <% if (el.hasVoted) { %>
                  <span class="badge badge-success"><i class="fas fa-check"></i> VOTED</span>
                <% } else if (el.isActive) { %>
                  <span class="badge badge-info">ACTIVE</span>
                <% } else if (el.status === 'closed') { %>
                  <span class="badge badge-gray">CLOSED</span>
                <% } else if (el.status === 'draft') { %>
                  <span class="badge badge-warning">UPCOMING</span>
                <% } else { %>
                  <span class="badge badge-gray"><%= el.status.toUpperCase() %></span>
                <% } %>
              </span>
              <h3><%= el.title %></h3>
              <p class="election-desc"><%= el.description %></p>
              <div class="election-meta">
                <span><i class="fas fa-users"></i> <%= el.candidateCount %> candidates</span>
                <span><i class="fas fa-chart-bar"></i> <%= el.voteCount %> votes</span>
              </div>
              <a href="/dashboard/election/<%= el.id %>" class="btn btn-outline btn-sm"><i class="fas fa-eye"></i> View Details</a>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
