<%- include('../partials/head') %>
<div class="app-container">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>

    <div class="page-header">
      <div>
        <h2><i class="fas fa-receipt"></i> Verify Your Vote</h2>
        <p>Enter your receipt code to verify your vote was correctly recorded.</p>
      </div>
      <a href="/dashboard" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back</a>
    </div>

    <div class="card" style="max-width: 600px;">
      <form method="POST" action="/dashboard/verify">
        <div class="form-group">
          <label for="receiptCode">Receipt Code</label>
          <input type="text" id="receiptCode" name="receiptCode" class="form-control" 
                 placeholder="Enter your vote receipt code" required 
                 style="font-family: 'Courier New', monospace; letter-spacing: 1px;">
        </div>
        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Verify</button>
      </form>
    </div>

    <% if (receipt) { %>
      <div class="card" style="margin-top: 1.5rem; max-width: 600px;">
        <div class="card-header">
          <h3><i class="fas fa-check-circle" style="color: #34d399;"></i> Vote Verified</h3>
          <span class="badge badge-success">CONFIRMED</span>
        </div>
        <div class="receipt-box">
          <p style="color: var(--text-muted); margin-bottom: 1rem;">Your vote has been located and verified in the system.</p>
          <div style="text-align: left; max-width: 400px; margin: 0 auto;">
            <p style="margin-bottom: 0.5rem;"><strong>Election:</strong> <%= receipt.electionTitle %></p>
            <p style="margin-bottom: 0.5rem;"><strong>Vote Hash:</strong></p>
            <p class="receipt-code" style="font-size: 0.75rem;"><%= receipt.vote_hash %></p>
            <p style="margin-bottom: 0.5rem;"><strong>Cast At:</strong> <%= new Date(receipt.cast_at).toLocaleString() %></p>
          </div>
          <div class="security-banner" style="margin-top: 1rem; margin-bottom: 0;">
            <i class="fas fa-shield-halved"></i>
            <span>Vote integrity confirmed — SHA-256 hash verified</span>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
